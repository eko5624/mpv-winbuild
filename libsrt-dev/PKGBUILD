pkgname=libsrt-dev
pkgver=1.5.3
pkgrel=1
pkgdesc='A transport protocol for ultra low (sub-second) latency live video and audio streaming'
arch=('x86_64')
url="https://www.srtalliance.org/"
makedepends=('openssl-dev')
license=('MPL')
source=("git+https://github.com/Haivision/srt.git")
md5sums=('SKIP')

build() { 
  export PATH="${TOP_DIR}/cross/bin:$PATH"
  export PKG_CONFIG_LIBDIR="${MINGW_PREFIX}/lib/pkgconfig"
  export PKG_CONFIG="pkgconf --static"
  cd $srcdir/srt
  rm -rf build && mkdir build && cd build
  cmake .. -G Ninja \
    -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
    -DCMAKE_TOOLCHAIN_FILE=../../../toolchain.cmake \
    -DCMAKE_BUILD_TYPE=Release \
    -DENABLE_SHARED=OFF \
    -DENABLE_STATIC=ON \
    -DUSE_STATIC_LIBSTDCXX=ON \
    -DENABLE_CXX_DEPS=OFF \
    -DUSE_ENCLIB=openssl \
    -DENABLE_APPS=OFF \
    -DCMAKE_C_FLAGS='-static-libgcc -static-libstdc++' \
    -DCMAKE_CXX_FLAGS='-static-libgcc -static-libstdc++' 
  ninja
}

package() {
  cd $srcdir/srt/build
  DESTDIR=$pkgdir ninja install
}
