SET(CMAKE_SYSTEM_NAME Windows)
SET(CMAKE_SYSTEM_PROCESSOR x86_64)

SET(CMAKE_C_COMPILER x86_64-w64-mingw32-gcc)
SET(CMAKE_CXX_COMPILER x86_64-w64-mingw32-g++)
SET(CMAKE_ASM_COMPILER x86_64-w64-mingw32-as)
SET(CMAKE_RC_COMPILER x86_64-w64-mingw32-windres)
SET(CMAKE_RANLIB x86_64-w64-mingw32-ranlib)

SET(CMAKE_FIND_ROOT_PATH /github/home/opt)

SET(CMAKE_C_COMPILER_WORKS ON)
SET(CMAKE_CXX_COMPILER_WORKS ON)
SET(CMAKE_ASM_COMPILER_WORKS ON)
SET(CMAKE_RC_COMPILER_WORKS ON)
SET(CMAKE_USE_PTHREADS_INIT 0)
SET(CMAKE_USE_WIN32_THREADS_INIT 1)
SET(CMAKE_HAVE_PTHREAD_CREATE OFF)
SET(CMAKE_HAVE_PTHREADS_CREATE OFF)
SET(CMAKE_HAVE_LIBC_PTHREAD OFF)
SET(THREADS_HAVE_PTHREAD_ARG OFF)
SET(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
SET(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
SET(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
