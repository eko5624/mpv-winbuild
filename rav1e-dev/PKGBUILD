pkgname=rav1e-dev
pkgver=0.6.6
pkgrel=1
pkgdesc='The fastest and safest AV1 encoder'
arch=('x86_64')
url="https://github.com/xiph/rav1e/"
license=('spdx:BSD-2-Clause')
source=("git+https://github.com/xiph/rav1e.git")
md5sums=('SKIP')

package() {
  export PATH="${TOP_DIR}/cross/bin:${TOP_DIR}/rust/.cargo/bin:$PATH"
  export PKG_CONFIG_LIBDIR="${MINGW_PREFIX}/lib/pkgconfig"
  export PKG_CONFIG="pkgconf --static"
  export RUSTUP_HOME="${TOP_DIR}/rust/.rustup"
  export CARGO_HOME="${TOP_DIR}/rust/.cargo"
  cat <<EOF >$CARGO_HOME/config
[net]
git-fetch-with-cli = true

[target.x86_64-pc-windows-gnu]
linker = "${TOP_DIR}/cross/bin/x86_64-w64-mingw32-gcc"
ar = "${TOP_DIR}/cross/bin/x86_64-w64-mingw32-ar"
rustflags = ["-C", "target-cpu=x86-64"]

[profile.release]
panic = "abort"
strip = true
EOF
  cd $srcdir/rav1e
  mkdir build
  export CARGO_BUILD_TARGET_DIR=build
  export CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1
  export CARGO_PROFILE_RELEASE_DEBUG=false
  export CARGO_PROFILE_RELEASE_INCREMENTAL=false
  export CARGO_PROFILE_RELEASE_LTO=off
  cargo cinstall --manifest-path=Cargo.toml --prefix=${MINGW_PREFIX} --destdir=$pkgdir --release --target x86_64-pc-windows-gnu --crt-static --library-type staticlib
}
