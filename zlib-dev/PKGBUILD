pkgname=zlib-dev
pkgver=1.3
pkgrel=1
pkgdesc='Compression library implementing the deflate compression method found in gzip and PKZIP'
arch=('x86_64')
url="https://github.com/madler/zlib/"
license=('ZLIB')
source=("git+https://github.com/madler/zlib.git")
md5sums=('SKIP')

build() {
  export PATH="${TOP_DIR}/cross/bin:$PATH"
  export PKG_CONFIG_LIBDIR="${MINGW_PREFIX}/lib/pkgconfig"
  export PKG_CONFIG="pkgconf --static"
  cd $srcdir/zlib
  rm -rf build && mkdir build && cd build
  cmake .. -G Ninja \
    -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
    -DCMAKE_TOOLCHAIN_FILE=../../../toolchain.cmake \
    -DCMAKE_BUILD_TYPE=Release \
    -DINSTALL_PKGCONFIG_DIR=${MINGW_PREFIX}/lib/pkgconfig \
    -DSKIP_INSTALL_LIBRARIES=ON \
    -DBUILD_SHARED_LIBS=OFF \
  ninja
}

package() {
  cd $srcdir/zlib/build
  DESTDIR=$pkgdir ninja install
  cp libzlibstatic.a $pkgdir${MINGW_PREFIX}/lib/libz.a
}
