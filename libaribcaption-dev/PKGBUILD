pkgname=libaribcaption-dev
pkgver=1.1.1
pkgrel=1
pkgdesc='Portable ARIB STD-B24 Caption Decoder/Renderer'
arch=('x86_64')
url="https://github.com/xqq/libaribcaption/"
makedepends=('openssl-dev')
license=('MIT')
source=("git+https://github.com/xqq/libaribcaption.git")
md5sums=('SKIP')

build() {
  export PATH="${TOP_DIR}/cross/bin:$PATH"
  export PKG_CONFIG_LIBDIR="${MINGW_PREFIX}/lib/pkgconfig"
  export PKG_CONFIG="pkgconf --static" 
  #export CXXFLAGS="$CXXFLAGS -DHAVE_OPENSSL=1"
  #export CFLAGS="$CFLAGS -DHAVE_OPENSSL=1"
  cd $srcdir/libaribcaption
  rm -rf build && mkdir build && cd build
  cmake .. \
    -G "Ninja" \
    -DCMAKE_INSTALL_PREFIX="${MINGW_PREFIX}" \
    -DCMAKE_TOOLCHAIN_FILE=../../../toolchain.cmake \
    -DCMAKE_FIND_ROOT_PATH="${MINGW_PREFIX}" \
    -DCMAKE_BUILD_TYPE=Release \
    -DBUILD_SHARED_LIBS=OFF \
    -DARIBCC_BUILD_TESTS=OFF \
    -DARIBCC_SHARED_LIBRARY=OFF \
    -DARIBCC_NO_RTTI=ON \
    -DCMAKE_C_FLAGS='$CMAKE_C_FLAGS -DHAVE_OPENSSL=1' \
    -DCMAKE_CXX_FLAGS='$CMAKE_CXX_FLAGS -DHAVE_OPENSSL=1'
  cmake --build .
}

package() {
  cd $srcdir/libaribcaption/build
  DESTDIR=$pkgdir cmake --install .
}
