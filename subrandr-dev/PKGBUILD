pkgname=subrandr-dev
pkgver=1.2.0
pkgrel=1
pkgdesc='An experimental subtitle rendering library'
arch=('x86_64')
url="https://github.com/afishhh/subrandr"
makedepends=("freetype2-dev" "harfbuzz-dev")
license=('MPL-2.0')
source=("git+https://github.com/afishhh/subrandr.git")
md5sums=('SKIP')

package() {
  cd $srcdir/subrandr
  export LD_PRELOAD=""
  export CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1
  cargo -Z unstable-options xtask install \
    --prefix="${MINGW_PREFIX}" \
    --destdir=$pkgdir \
    --target x86_64-pc-windows-${rust_target} \
    --static-library true \
    --shared-library false
  mkdir -p $pkgdir${MINGW_PREFIX}
  mv $pkgdir/include $pkgdir${MINGW_PREFIX}
  mv $pkgdir/lib $pkgdir${MINGW_PREFIX}
}