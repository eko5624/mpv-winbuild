pkgname=vapoursynth-dev
pkgver=75
pkgrel=1
pkgdesc='A video processing framework with the future in mind'
arch=('x86_64')
url="http://www.vapoursynth.com/"
license=('LGPL')
source=()
md5sums=()

package() {
  cd $srcdir
  set -x
  git clone \
    --depth 1 \
    --sparse \
    --filter=tree:0 \
    https://github.com/vapoursynth/vapoursynth.git
  cd vapoursynth
  git sparse-checkout set --no-cone '/include' '!include/cython'
  mkdir -p $pkgdir${MINGW_PREFIX}/lib/pkgconfig
  mkdir -p $pkgdir${MINGW_PREFIX}/include/vapoursynth
  find . -type f -name "*.h" -print0 | xargs -0 -I {} cp {} $pkgdir${MINGW_PREFIX}/include/vapoursynth
  cp include/*.h $pkgdir${MINGW_PREFIX}/include/vapoursynth
  cp ../../*.pc $pkgdir${MINGW_PREFIX}/lib/pkgconfig
  for i in $pkgdir${MINGW_PREFIX}/lib/pkgconfig/*.pc; do
    sed -e "s|@MINGW_PREFIX@|${MINGW_PREFIX}|g" \
        -e "s|_ver|$pkgver|g" \
        -i "$i"
  done    
}
